      },
      {
        "netclass": "SDRAM_DATA",
        "pattern": "^SDRAM_D[0-9]+$"
      },
      {
        "netclass": "SDRAM_ADDR_CTRL",
        "pattern": "^SDRAM_(B?A[0-9]+|n.+|CKE)"
      },
      {
        "netclass": "USB_PULL",
        "pattern": "USB_FPGA_PULL_D\\-|\\+]"
      },
      {
        "netclass": "USB_DIFF_OTHER",
        "pattern": "USB_(FPGA)_D[\\-|\\+]"
      },
      {
        "netclass": "PWR_5V_IN",
        "pattern": "USB5V|\\+5V"
      },
      {
        "netclass": "PWR_BUCK_SW",
        "pattern": "/power/L[0-9]+$"
      },
      {
        "netclass": "PWR_BUCK_OUT",
        "pattern": "/power/P[0-9]+V[0-9]+$"
      },
      {
        "netclass": "PWR_RAIL",
        "pattern": "^\\+[0-9]V[0-9]|[0-9]V[0-9]_[0-9]V[0-9]$"
      }
    ]
  },
