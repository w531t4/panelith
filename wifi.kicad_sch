				(size 1.524 1.524)
			)
		)
		(uuid "d3c87592-1f7e-4850-b0d5-a26dd9a347ab")
	)
	(text "R56 makes ESP32 boot at power up\nno R56: FPGA should pull up GPIO0\nand pulse EN for ESP32 to boot"
