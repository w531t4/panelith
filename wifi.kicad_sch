	)
	(text "ESP32 JTAG slave interface\nEN: TRST_N\nGPIO15: TDO\nGPIO12: TDI\nGPIO13: TCK\nGPIO14: TMS\nFLASH over JTAG\nnot yet supported."
		(exclude_from_sim no)
		(at 116.332 188.976 0)
		(effects
