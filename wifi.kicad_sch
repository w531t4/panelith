		(uuid "b065a04e-6e48-42fd-8956-b576be65e317")
	)
	(text "Strapping Pins: GPIO{2,3,45,46}\nWIFIEN no longer manipulates strapping - but it still does impact devices on-off. \nGPIO 0/46 now control boot behavior. replace EN for 46 in FPGA image"
		(exclude_from_sim no)
		(at 172.466 34.29 0)
		(effects
