	(text "New Pins:\n - WIFI_GPIO15_XTAL_D+/-\n - WIFI_GPIO{39,40,41,42} - ESP32's JTAG\n - WIFI_GPIO{3,8,9,10,11,12,13,14,38,46}\n - WIFI_USB_D+/-\n\nNewly unconnected\n - WIFI_GPIO35\n\nNewly removed\n - WIFI_GPIO{19,21,22,25,26,27}"
		(exclude_from_sim no)
		(at 17.526 178.562 0)
		(effects
			(font
				(size 1.524 1.524)
			)
			(justify left)
		)
		(uuid "593bd2f9-1221-476f-8c7c-096c04bd0bfb")
	)
